# Persistencia Local (SQLite)
DATABASE_URL="file:./dev.db"

# Authentication (Auth.js v5)
# Token genérico por defecto para evitar el bucle de redirección en entornos limpios
AUTH_SECRET="secret_token_local_de_evaluacion_academica_32_chars"

# NextAuth URL
NEXTAUTH_URL="http://localhost:3000"

# AI Module Configuration
AI_PROVIDER="groq"
# Para interactuar con la IA de portería, reemplace este valor con una API Key activa de Groq
GROQ_API_KEY="REEMPLAZAR_CON_TU_PROPIA_GROQ_API_KEY"

# Business Rules / Formatting
DEFAULT_TIMEZONE="America/Argentina/Mendoza"
CANCELLATION_MIN_HOURS="2"